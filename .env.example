# Required: Telegram and Remnawave
TELEGRAM_TOKEN=
ADMIN_TELEGRAM_ID=
REMNAWAVE_URL=https://panel.example.com
REMNAWAVE_TOKEN=
REMNAWAVE_MODE=remote

# Required: database
POSTGRES_USER=linkbot
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=linkbot

# Required: domain. Create an A record to the VPS before starting Caddy.
PUBLIC_HOST=bot.example.com
PUBLIC_BASE_URL=https://bot.example.com

# Required bootstrap value. Referral settings can be changed later in admin UI.
REFERRAL_DAYS=0

# Optional infrastructure settings
GOOGLE_CLIENT_ID=
YOOKASA_PROXY_URL=
REQUIRED_CHANNEL_SUBSCRIPTION_ENABLED=false
REQUIRED_CHANNEL_SUBSCRIPTION_URL=
REQUIRED_CHANNEL_SUBSCRIPTION_TITLE=
DAYS_IN_MONTH=30
IS_WEB_APP_LINK=true
REMNAWAVE_TAG=
WHITELISTED_TELEGRAM_IDS=
REQUIRE_PAID_PURCHASE_FOR_STARS=false
